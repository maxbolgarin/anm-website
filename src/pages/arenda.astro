---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import OfficeFilterIsland from '@components/OfficeFilterIsland.astro';
import ContactCTA from '@components/ContactCTA.astro';

const title = 'Аренда офисов — свободные помещения в бизнес-центрах АНМ';
const description = 'Актуальные предложения аренды офисов в бизнес-центрах Фидель и БЦ АНМ на территории Александро-Невской Мануфактуры. Подберите офис по площади, этажу и бюджету.';

const breadcrumbs = [
  { label: 'Главная', href: '/' },
  { label: 'Аренда' },
];
---

<BaseLayout title={title} description={description}>
  <Breadcrumbs items={breadcrumbs} />

  <section class="arenda">
    <div class="container">
      <h1 class="arenda__title">Аренда офисов</h1>

      <OfficeFilterIsland />
    </div>
  </section>

  <!-- ===== CONTACT CTA ===== -->
  <ContactCTA />
</BaseLayout>

<style>
  .arenda {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .arenda__title {
    font-size: var(--text-h1);
    margin-bottom: var(--space-xl);
  }
</style>
