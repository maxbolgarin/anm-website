---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import SectionHeading from '@components/SectionHeading.astro';
import StatsRow from '@components/StatsRow.astro';
import FeatureBlock from '@components/FeatureBlock.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { withBase } from '@utils/withBase';

const title = 'Компания и история — АНМ';
const description = 'АНМ — девелоперская компания с 20-летним опытом. Редевелопмент промышленных территорий, управление бизнес-центрами в СПб.';

const breadcrumbs = [
  { label: 'Главная', href: '/' },
  { label: 'О компании', href: '/about/' },
  { label: 'Компания и история' },
];

const companyStats = [
  { value: '20+', label: 'лет на рынке' },
  { value: '21 376', label: 'м² под управлением' },
  { value: '80+', label: 'арендаторов' },
];

const historyEvents = [
  { year: '1837', title: 'Основание фабрики', description: 'На территории нынешнего имущественного комплекса основана ситце-печатная фабрика Паля — одно из крупнейших текстильных производств Санкт-Петербурга.', image: '/history/3D_Isometric_Map_In_a_vintage_industrial_style_a_large_textile_Z2ehCCb2.png' },
  { year: '1855', title: 'Строительство главного здания', description: 'Построено здание нынешнего БЦ «Фидель» (Литер А, корп. 3) как часть производственных помещений ткацкой фабрики Паля.', image: '/history/3D_Isometric_Map_A_large_brick_building_is_undergoing_demolition.png' },
  { year: '1976', title: 'Строительство АБК', description: 'Возведено шестиэтажное административное здание «АБК» (Литер А, корп. 2), которое впоследствии стало бизнес-центром АНМ.', image: '/history/3D_Isometric_Map_MoUcVrn8.png' },
  { year: '2004', title: 'Создание компании', description: 'Основано ЗАО «Александро-Невская мануфактура». Приобретён имущественный комплекс на Пр. Обуховской Обороны для редевелопмента территории.', image: '/history/_DSC3708.jpg' },
  { year: '2006', title: 'Начало реконструкции', description: 'Принято решение о сохранении исторического здания 1855 года. Совместно с Архитектурным Бюро «INTERCOLUMNIUM» разработан проект реконструкции бизнес-лофта.', image: '/history/3D_Isometric_Map_In_a_architectural_visualization_style_this_7tyc4192.png' },
  { year: '2009', title: 'Открытие бизнес-лофта «Фидель»', description: 'Завершена реконструкция и введён в эксплуатацию бизнес-лофт «Фидель» класса B+. С момента открытия заполняемость поддерживается на уровне 100%.', image: '/history/вид слева.JPG' },
  { year: '2019', title: 'Новый этап редевелопмента', description: 'Начало работ по редевелопменту территории с целью возведения новых объектов коммерческой недвижимости. Реконструкция и модернизация инженерных систем.', image: '/history/image_2026-03-24_17-51-39.png' },
];

const trustStats = [
  { value: '80+', label: 'арендаторов' },
  { value: '10+', label: 'лет средний срок аренды' },
  { value: '98%', label: 'продлевают договор' },
];

const tenants = [
  { name: 'Компания 1', logo: '/companies/1.svg', maxH: '200px' },
  { name: 'Компания 2', logo: '/companies/2.svg', maxH: '170px' },
  { name: 'Компания 3', logo: '/companies/3.svg', maxH: '95px' },
  { name: 'Компания 4', logo: '/companies/4.svg' },
  { name: 'Компания 5', logo: '/companies/5.png', maxH: '100px' },
  { name: 'Компания 6', logo: '/companies/6.png', maxH: '120px' },
  { name: 'Marstar', logo: '/companies/marstar.png', maxH: '140px' },
];

const managementBlocks = [
  {
    title: 'Европейский уровень обслуживания',
    description: 'Профессиональная служба заботы обеспечивает высокий уровень комфорта для арендаторов. Круглосуточная поддержка, оперативное решение вопросов, индивидуальный подход к каждому клиенту.',
    image: '/images/buildings/fidel/interior-1.jpg',
    imageAlt: 'Дизайнерский ресепшн в бизнес-центре Фидель',
  },
  {
    title: 'Инженерные решения',
    description: 'Современные инженерные системы обеспечивают надёжность и энергоэффективность. Электроснабжение II категории, централизованное кондиционирование, собственная газовая котельная, 6 телеком-операторов.',
    image: '/фото бц/web (27).jpg',
    imageAlt: 'Инженерные системы бизнес-центра',
  },
  {
    title: 'Редевелопмент промышленных территорий',
    description: 'Наша экспертиза — трансформация бывших промышленных зданий в современные бизнес-пространства. Мы сохраняем характер исторических зданий, наполняя их современными технологиями и комфортом.',
    image: '/images/about/territory-drone.jpg',
    imageAlt: 'Территория Александро-Невской Мануфактуры с высоты',
  },
];
---

<BaseLayout title={title} description={description}>
  <Breadcrumbs items={breadcrumbs} />

  <!-- ===== SECTION 1: COMPANY HERO ===== -->
  <section class="about-hero">
    <div class="container">
      <div class="about-hero__grid">
        <div class="about-hero__text">
          <h1 class="about-hero__name">Александро-Невская Мануфактура</h1>
          <p class="about-hero__tagline">Управляющая компания. Создаём качественные бизнес&#8209;пространства в&nbsp;Санкт&#8209;Петербурге.</p>
          <StatsRow stats={companyStats} />
        </div>
        <div class="about-hero__image-wrap">
          <img src={withBase('/territory/DJI_0739 (1) (1).jpg')} alt="Панорама территории Александро-Невской Мануфактуры" class="about-hero__image" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: COMPANY DESCRIPTION ===== -->
  <section class="section section--cream">
    <div class="container about-description">
      <h2>О компании</h2>
      <p>
        АНМ — девелоперская и управляющая компания, работающая на рынке коммерческой недвижимости Санкт-Петербурга более 20 лет. Наша миссия — создание комфортной среды для бизнес-сообщества через редевелопмент промышленных территорий.
      </p>
      <p>
        Основной проект компании — развитие и управление территорией бывшей промышленной зоны на Проспекте Обуховской Обороны. Концепция редевелопмента разработана британским архитектурным бюро Horan Keoghan Ryan Limited и предусматривает превращение исторических промышленных зданий в современные бизнес-центры с сохранением их уникального характера.
      </p>
      <p>
        Сегодня на территории Александро-Невской Мануфактуры работают бизнес-центры класса B+, обеспечивающие арендаторам все уровни комфорта: от современных инженерных систем до развитой инфраструктуры и прогулочной зоны на набережной реки Невы. Управляющая компания берет на себя решение всех хозяйственных вопросов и обеспечивает максимально комфортные условия для ведения бизнеса.
      </p>
    </div>
  </section>

  <!-- ===== SECTION 3: HISTORY ===== -->
  <section class="section" id="history">
    <div class="container">
      <SectionHeading title="История компании" subtitle="Ключевые этапы развития" />
      <div class="timeline">
        {historyEvents.map((event) => (
          <div class="timeline__item">
            <div class="timeline__image-wrap">
              {event.image && <img src={withBase(event.image)} alt={event.title} class="timeline__image" loading="lazy" />}
            </div>
            <div class="timeline__line">
              <span class="timeline__dot"></span>
            </div>
            <div class="timeline__content">
              <div class="timeline__year">{event.year}</div>
              <h3 class="timeline__title">{event.title}</h3>
              <p class="timeline__desc">{event.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SECTION 4: MANAGEMENT APPROACH ===== -->
  <section class="section section--cream">
    <div class="container">
      <SectionHeading title="Наш подход" subtitle="Принципы работы управляющей компании" />
      {managementBlocks.map((block, index) => (
        <FeatureBlock
          title={block.title}
          description={block.description}
          image={block.image}
          imageAlt={block.imageAlt}
          reversed={index % 2 !== 0}
        />
      ))}
    </div>
  </section>

  <!-- ===== SECTION 5: TRUST / TENANTS ===== -->
  <section class="section" id="trust">
    <div class="container">
      <SectionHeading
        title="Нам доверяют"
        subtitle="Более 120 компаний выбрали наши бизнес-центры для размещения своих офисов"
        align="center"
      />
      <div class="trust-stats">
        {trustStats.map((stat) => (
          <div class="trust-stats__item">
            <span class="trust-stats__value">{stat.value}</span>
            <span class="trust-stats__label">{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="tenants-grid">
        {tenants.map((tenant) => (
          <div class="tenant-card">
            {tenant.logo ? (
              <img src={withBase(tenant.logo)} alt={tenant.name} class="tenant-card__logo-img" style={tenant.maxH ? `max-height: ${tenant.maxH}` : ''} />
            ) : (
              <div class="tenant-card__logo">{tenant.initials}</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SECTION 6: CONTACT CTA ===== -->
  <ContactCTA />
</BaseLayout>

<style>
  .about-hero {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .about-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: stretch;
  }

  .about-hero__name {
    margin-bottom: var(--space-lg);
    font-family: var(--font-heading);
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    line-height: 1.0;
  }

  .about-hero__tagline {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2xl);
  }

  .about-hero__image-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    height: 100%;
  }

  .about-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-description {
    max-width: 48rem;
  }

  .about-description h2 {
    margin-bottom: var(--space-xl);
  }

  .about-description p {
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 14rem 2.5rem 1fr;
    gap: 0;
    align-items: start;
  }

  .timeline__image-wrap {
    padding-right: var(--space-lg);
    padding-bottom: var(--space-2xl);
  }

  .timeline__image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-md, 0.5rem);
  }

  .timeline__line {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    height: 100%;
  }

  .timeline__line::before {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: var(--color-primary);
  }

  .timeline__dot {
    position: relative;
    z-index: 1;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 4px;
  }

  .timeline__content {
    padding-left: var(--space-lg);
    padding-bottom: var(--space-2xl);
  }

  .timeline__year {
    font-family: var(--font-heading);
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
    line-height: 1;
  }

  .timeline__title {
    margin-bottom: var(--space-sm);
    font-size: var(--text-body);
  }

  .timeline__desc {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    font-size: var(--text-caption);
    max-width: none;
  }

  @media (max-width: 767px) {
    .timeline__item {
      grid-template-columns: 2rem 1fr;
    }

    .timeline__image-wrap {
      display: none;
    }

    .timeline__line {
      grid-column: 1;
    }

    .timeline__content {
      grid-column: 2;
      padding-left: var(--space-md);
    }
  }

  /* Trust section */
  #trust :global(.section-heading__subtitle) {
    max-width: none;
  }

  .trust-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
    flex-wrap: wrap;
  }

  .trust-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .trust-stats__value {
    font-family: var(--font-heading);
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    line-height: 1.1;
  }

  .trust-stats__label {
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .tenants-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .tenant-card {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100px;
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-surface-cream);
    border-radius: var(--radius-md);
    text-align: center;
    transition: box-shadow 0.2s ease;
  }

  .tenant-card:hover {
    box-shadow: var(--shadow-md);
  }

  .tenant-card__logo {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface-white);
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-bold);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .tenant-card__logo-img {
    max-width: 270px;
    max-height: 120px;
    object-fit: contain;
  }

  .tenant-card__name {
    font-size: var(--text-small);
    color: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }

  @media (max-width: 1023px) {
    .tenants-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 767px) {
    .about-hero__grid {
      grid-template-columns: 1fr;
    }

    .trust-stats {
      gap: var(--space-xl);
    }

    .tenants-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
