---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import SectionHeading from '@components/SectionHeading.astro';
import StatsRow from '@components/StatsRow.astro';
import InteractiveMapIsland from '@components/InteractiveMapIsland.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { buildings } from '@data/buildings';
import { withBase } from '@utils/withBase';

const title = 'О компании АНМ — управляющая компания в Санкт-Петербурге';
const description = 'АНМ — девелоперская компания с 20-летним опытом. Два бизнес-центра, 22 000 м² под управлением, 80+ арендаторов в Санкт-Петербурге.';

const breadcrumbs = [
  { label: 'Главная', href: '/' },
  { label: 'О компании' },
];

const companyStats = [
  { value: '20+', label: 'лет на рынке' },
  { value: '21 376', label: 'м² под управлением' },
  { value: '80+', label: 'арендаторов' },
];

const managementServices = [
  { icon: '🔧', name: 'Техническое обслуживание', description: 'Собственная служба эксплуатации. Электрики, сантехники, инженеры — на месте 24/7.' },
  { icon: '✨', name: 'Клининг', description: 'Профессиональная уборка общих зон и офисов. Ежедневно и по запросу.' },
  { icon: '🛡', name: 'Охрана и безопасность', description: 'Круглосуточная охрана, видеонаблюдение, контроль доступа по картам.' },
  { icon: '🔑', name: 'Пропускная система', description: 'Электронные пропуска для сотрудников и гостей. Заказ через личный кабинет.' },
  { icon: '📞', name: 'Служба заботы', description: 'Одна точка контакта для всех вопросов. Быстрое решение любых задач.' },
  { icon: '📅', name: 'Бронирование переговорных', description: 'Современные переговорные комнаты. Онлайн-бронирование для арендаторов.' },
];

const mapMarkers = buildings.map((b) => ({
  lat: b.coordinates.lat,
  lng: b.coordinates.lng,
  title: `БЦ ${b.name}`,
  address: b.shortAddress,
  href: `/buildings/${b.slug}/`,
}));

const trustStats = [
  { value: '80+', label: 'арендаторов' },
  { value: '10+', label: 'лет средний срок аренды' },
  { value: '98%', label: 'продлевают договор' },
];

const tenants = [
  { name: 'Компания 1', logo: '/companies/1.svg', maxH: '115px' },
  { name: 'Компания 2', logo: '/companies/2.svg', maxH: '100px' },
  { name: 'Компания 3', logo: '/companies/3.svg', maxH: '55px' },
  { name: 'Компания 4', logo: '/companies/4.svg' },
  { name: 'Мегафон', initials: 'МФ' },
  { name: 'Deloitte', initials: 'DL' },
  { name: 'Балтика', initials: 'БЛ' },
  { name: 'Петербургтеплоэнерго', initials: 'ПТЭ' },
];
---

<BaseLayout title={title} description={description}>
  <Breadcrumbs items={breadcrumbs} />

  <!-- ===== SECTION 1: COMPANY HERO (condensed from company page) ===== -->
  <section class="about-hero">
    <div class="container">
      <div class="about-hero__grid">
        <div class="about-hero__text">
          <h1 class="about-hero__name text-display">Александро-Невская Мануфактура</h1>
          <p class="about-hero__tagline">Управляющая компания. Создаём качественные бизнес&#8209;пространства в&nbsp;Санкт&#8209;Петербурге.</p>
          <StatsRow stats={companyStats} />
          <a href={withBase('/about/company/')} class="btn--link about-hero__link">Подробнее →</a>
        </div>
        <div class="about-hero__image-wrap">
          <img src={withBase('/images/about/territory-panorama-new.jpg')} alt="Панорама территории Александро-Невской Мануфактуры" class="about-hero__image" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 2: TERRITORY MAP (condensed from territory page) ===== -->
  <section class="section section--cream" id="territory">
    <div class="container">
      <SectionHeading
        title="Локация"
        subtitle="Александро-Невская Мануфактура — это два бизнес-центра на исторической территории у набережной Невы с развитой инфраструктурой для комфортной работы."
      />
    </div>
    <div class="map-section">
      <InteractiveMapIsland
        markers={mapMarkers}
        center={{ lat: 59.9010, lng: 30.4295 }}
        zoom={16}
        height="400px"
      />
    </div>
    <div class="container territory-link-wrap">
      <a href={withBase('/territory/')} class="btn--link">Подробнее →</a>
    </div>
  </section>

  <!-- ===== SECTION 3: MANAGEMENT COMPANY ===== -->
  <section class="section" id="management">
    <div class="container">
      <div class="mgmt-header">
        <span class="mgmt-header__label">Управляющая компания</span>
        <p class="mgmt-header__subtitle">
          Собственная управляющая компания с 20-летним опытом. Мы знаем, что нужно вашему бизнесу.
        </p>
      </div>
      <div class="mgmt-grid">
        {managementServices.map((svc) => (
          <div class="mgmt-card">
            <span class="mgmt-card__icon">{svc.icon}</span>
            <h3 class="mgmt-card__name">{svc.name}</h3>
            <p class="mgmt-card__desc">{svc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SECTION 4: TRUST / TENANTS ===== -->
  <section class="section trust-section" id="trust">
    <div class="container">
      <SectionHeading
        title="Нам доверяют"
        subtitle="Более 120 компаний выбрали наши бизнес-центры для размещения своих офисов"
        align="center"
      />
      <div class="trust-stats">
        {trustStats.map((stat) => (
          <div class="trust-stats__item">
            <span class="trust-stats__value">{stat.value}</span>
            <span class="trust-stats__label">{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="tenants-grid">
        {tenants.map((tenant) => (
          <div class="tenant-card">
            {tenant.logo ? (
              <img src={withBase(tenant.logo)} alt={tenant.name} class="tenant-card__logo-img" style={tenant.maxH ? `max-height: ${tenant.maxH}` : ''} />
            ) : (
              <div class="tenant-card__logo">{tenant.initials}</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SECTION 4: CONTACT CTA ===== -->
  <ContactCTA />
</BaseLayout>

<style>
  /* Hero */
  .about-hero {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .about-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: stretch;
  }

  .about-hero__name {
    margin-bottom: var(--space-lg);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
  }

  .about-hero__tagline {
    font-size: var(--text-h4);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2xl);
  }

  .about-hero__link {
    display: inline-block;
    margin-top: var(--space-xl);
  }

  .about-hero__image-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    height: 100%;
  }

  .about-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Link button style */
  .btn--link {
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .btn--link:hover {
    color: var(--color-primary-dark);
  }

  /* Territory section */
  .map-section {
    margin-top: var(--space-xl);
  }

  .territory-link-wrap {
    margin-top: var(--space-lg);
  }

  /* Trust section — wider subtitle */
  .trust-section :global(.section-heading__subtitle) {
    max-width: none;
  }

  /* Trust stats */
  .trust-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
    flex-wrap: wrap;
  }

  .trust-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .trust-stats__value {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    line-height: 1.1;
  }

  .trust-stats__label {
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  /* Tenants grid */
  .tenants-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .tenant-card {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100px;
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-surface-cream);
    border-radius: var(--radius-md);
    text-align: center;
    transition: box-shadow 0.2s ease;
  }

  .tenant-card:hover {
    box-shadow: var(--shadow-md);
  }

  .tenant-card__logo {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface-white);
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    font-weight: var(--weight-bold);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .tenant-card__logo-img {
    max-width: 160px;
    max-height: 70px;
    object-fit: contain;
  }

  .tenant-card__name {
    font-size: var(--text-small);
    color: var(--color-text-primary);
    font-weight: var(--weight-medium);
  }

  /* Management company section */
  .mgmt-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .mgmt-header__label {
    display: inline-block;
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-lg);
  }

  .mgmt-header__subtitle {
    font-size: var(--text-h3);
    color: var(--color-text-primary);
    max-width: 36rem;
    margin-inline: auto;
    line-height: var(--leading-relaxed);
  }

  .mgmt-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .mgmt-card {
    background-color: var(--color-surface-cream);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    transition: box-shadow 0.2s ease;
  }

  .mgmt-card:hover {
    box-shadow: var(--shadow-md);
  }

  .mgmt-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background-color: var(--color-surface-cream);
    border-radius: var(--radius-sm);
    font-size: 1.5rem;
    margin-bottom: var(--space-lg);
  }

  .mgmt-card__name {
    font-size: var(--text-h4);
    margin-bottom: var(--space-sm);
  }

  .mgmt-card__desc {
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 1023px) {
    .tenants-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .mgmt-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .about-hero__grid {
      grid-template-columns: 1fr;
    }

    .trust-stats {
      gap: var(--space-xl);
    }

    .tenants-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .mgmt-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
