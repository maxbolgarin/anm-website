---
import BuildingLayout from '@layouts/BuildingLayout.astro';
import OfficeFilter from '@components/islands/OfficeFilter';
import '@components/islands/OfficeFilter.css';
import ContactCTA from '@components/ContactCTA.astro';
import { getBuildingBySlug } from '@data/buildings';
import { getBuildingEnBySlug } from '@data/buildings-en';

const building = getBuildingBySlug('anm')!;
const en = getBuildingEnBySlug('anm')!;

const title = `Office Rental in ${en.name} Business Center — Available Spaces | ANM`;
const description = `Office for rent in ${en.name} Business Center. Class B, 6th floor, 100.8 m², private office layout, fresh renovation. Direct lease from the owner.`;
---

<BuildingLayout
  title={title}
  description={description}
  buildingName={en.name}
  buildingSlug={building.slug}
>
  <section class="offices-section">
    <div class="container">
      <h1 class="offices-section__title">Office Rental in ANM Business Center</h1>

      <OfficeFilter
        client:visible
        locale="en"
        buildingSlug="anm"
        contactPhone="+7 (812) 336-55-64"
        contactEmail="arenda@ukanm.ru"
      />
    </div>
  </section>

  <ContactCTA />
</BuildingLayout>

<style>
  .offices-section {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .offices-section__title {
    font-size: var(--text-h1);
    margin-bottom: var(--space-2xl);
  }
</style>
