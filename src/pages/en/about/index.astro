---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import SectionHeading from '@components/SectionHeading.astro';
import StatsRow from '@components/StatsRow.astro';
import InteractiveMapIsland from '@components/InteractiveMapIsland.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { buildings } from '@data/buildings';
import { getBuildingEnBySlug, buildingsEn } from '@data/buildings-en';
import { withBase } from '@utils/withBase';

const title = 'About ANM — Property Management Company in St. Petersburg';
const description = 'ANM — a development company with 20+ years of experience. Two business centers, 21,376 m² under management, 80+ tenants in St. Petersburg.';

const breadcrumbs = [
  { label: 'Home', href: '/en/' },
  { label: 'About' },
];

const companyStats = [
  { value: '20+', label: 'years in market' },
  { value: '21,376', label: 'm² under management' },
  { value: '80+', label: 'tenants' },
];

const managementServices = [
  { icon: '🔧', name: 'Maintenance', description: 'In-house maintenance team. Electricians, plumbers, engineers — on-site 24/7.' },
  { icon: '✨', name: 'Cleaning', description: 'Professional cleaning of common areas and offices. Daily and on request.' },
  { icon: '🛡', name: 'Security', description: '24/7 security, CCTV surveillance, card-based access control.' },
  { icon: '🔑', name: 'Access System', description: 'Electronic passes for employees and guests. Ordering via personal portal.' },
  { icon: '📞', name: 'Concierge Service', description: 'Single point of contact for all matters. Quick resolution of any issues.' },
  { icon: '📅', name: 'Meeting Room Booking', description: 'Modern meeting rooms. Online booking for tenants.' },
];

const mapMarkers = buildings.map((b) => {
  const buildingEn = getBuildingEnBySlug(b.slug);
  return {
    lat: b.coordinates.lat,
    lng: b.coordinates.lng,
    title: `BC ${buildingEn?.name || b.name}`,
    address: buildingEn?.shortAddress || b.shortAddress,
    href: `/en/buildings/${b.slug}/`,
  };
});

const trustStats = [
  { value: '80+', label: 'tenants' },
  { value: '10+', label: 'years average lease term' },
  { value: '98%', label: 'renew their contract' },
];

const tenants = [
  { name: 'Company 1', logo: '/companies/1.svg', maxH: '115px' },
  { name: 'Company 2', logo: '/companies/2.svg', maxH: '100px' },
  { name: 'Company 3', logo: '/companies/3.svg', maxH: '55px' },
  { name: 'Company 4', logo: '/companies/4.svg' },
  { name: 'Megafon', initials: 'MF' },
  { name: 'Deloitte', initials: 'DL' },
  { name: 'Baltika', initials: 'BL' },
  { name: 'Peterburgteploenergo', initials: 'PTE' },
];
---

<BaseLayout title={title} description={description}>
  <Breadcrumbs items={breadcrumbs} />

  <section class="about-hero">
    <div class="container">
      <div class="about-hero__grid">
        <div class="about-hero__text">
          <h1 class="about-hero__name text-display">Aleksandro-Nevskaya Manufaktura</h1>
          <p class="about-hero__tagline">Property management company. Creating quality business spaces in St.&nbsp;Petersburg.</p>
          <StatsRow stats={companyStats} />
          <a href={withBase('/en/about/company/')} class="btn--link about-hero__link">Learn more →</a>
        </div>
        <div class="about-hero__image-wrap">
          <img src={withBase('/images/about/territory-panorama-new.jpg')} alt="Panorama of Aleksandro-Nevskaya Manufaktura territory" class="about-hero__image" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section--cream" id="territory">
    <div class="container">
      <SectionHeading
        title="Location"
        subtitle="Aleksandro-Nevskaya Manufaktura comprises two business centers on a historic site along the Neva River embankment with developed infrastructure for comfortable work."
      />
    </div>
    <div class="map-section">
      <InteractiveMapIsland
        markers={mapMarkers}
        center={{ lat: 59.9010, lng: 30.4295 }}
        zoom={16}
        height="400px"
      />
    </div>
    <div class="container territory-link-wrap">
      <a href={withBase('/en/territory/')} class="btn--link">Learn more →</a>
    </div>
  </section>

  <section class="section" id="management">
    <div class="container">
      <div class="mgmt-header">
        <span class="mgmt-header__label">Management Company</span>
        <p class="mgmt-header__subtitle">
          In-house management company with 20 years of experience. We know what your business needs.
        </p>
      </div>
      <div class="mgmt-grid">
        {managementServices.map((svc) => (
          <div class="mgmt-card">
            <span class="mgmt-card__icon">{svc.icon}</span>
            <h3 class="mgmt-card__name">{svc.name}</h3>
            <p class="mgmt-card__desc">{svc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section trust-section" id="trust">
    <div class="container">
      <SectionHeading
        title="Trusted By"
        subtitle="Over 120 companies have chosen our business centers for their offices"
        align="center"
      />
      <div class="trust-stats">
        {trustStats.map((stat) => (
          <div class="trust-stats__item">
            <span class="trust-stats__value">{stat.value}</span>
            <span class="trust-stats__label">{stat.label}</span>
          </div>
        ))}
      </div>
      <div class="tenants-grid">
        {tenants.map((tenant) => (
          <div class="tenant-card">
            {tenant.logo ? (
              <img src={withBase(tenant.logo)} alt={tenant.name} class="tenant-card__logo-img" style={tenant.maxH ? `max-height: ${tenant.maxH}` : ''} />
            ) : (
              <div class="tenant-card__logo">{tenant.initials}</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <ContactCTA />
</BaseLayout>

<style>
  .about-hero {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .about-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: stretch;
  }

  .about-hero__name {
    margin-bottom: var(--space-lg);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
  }

  .about-hero__tagline {
    font-size: var(--text-h4);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2xl);
  }

  .about-hero__link {
    display: inline-block;
    margin-top: var(--space-xl);
  }

  .about-hero__image-wrap {
    border-radius: var(--radius-md);
    overflow: hidden;
    height: 100%;
  }

  .about-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .btn--link {
    font-size: var(--text-body);
    font-weight: var(--weight-medium);
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .btn--link:hover {
    color: var(--color-primary-dark);
  }

  .map-section {
    margin-top: var(--space-xl);
  }

  .territory-link-wrap {
    margin-top: var(--space-lg);
  }

  .trust-section :global(.section-heading__subtitle) {
    max-width: none;
  }

  .trust-stats {
    display: flex;
    justify-content: center;
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
    flex-wrap: wrap;
  }

  .trust-stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .trust-stats__value {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    line-height: 1.1;
  }

  .trust-stats__label {
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
  }

  .tenants-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  .tenant-card {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100px;
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-surface-cream);
    border-radius: var(--radius-md);
    text-align: center;
    transition: box-shadow 0.2s ease;
  }

  .tenant-card:hover {
    box-shadow: var(--shadow-md);
  }

  .tenant-card__logo {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface-white);
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-size: var(--text-h4);
    font-weight: var(--weight-bold);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }

  .tenant-card__logo-img {
    max-width: 160px;
    max-height: 70px;
    object-fit: contain;
  }

  .mgmt-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .mgmt-header__label {
    display: inline-block;
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-lg);
  }

  .mgmt-header__subtitle {
    font-size: var(--text-h3);
    color: var(--color-text-primary);
    max-width: 36rem;
    margin-inline: auto;
    line-height: var(--leading-relaxed);
  }

  .mgmt-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .mgmt-card {
    background-color: var(--color-surface-cream);
    border-radius: var(--radius-md);
    padding: var(--space-xl);
    transition: box-shadow 0.2s ease;
  }

  .mgmt-card:hover {
    box-shadow: var(--shadow-md);
  }

  .mgmt-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background-color: var(--color-surface-cream);
    border-radius: var(--radius-sm);
    font-size: 1.5rem;
    margin-bottom: var(--space-lg);
  }

  .mgmt-card__name {
    font-size: var(--text-h4);
    margin-bottom: var(--space-sm);
  }

  .mgmt-card__desc {
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 1023px) {
    .tenants-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .mgmt-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .about-hero__grid {
      grid-template-columns: 1fr;
    }

    .trust-stats {
      gap: var(--space-xl);
    }

    .tenants-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .mgmt-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
