---
import BuildingLayout from '@layouts/BuildingLayout.astro';
import OfficeFilter from '@components/islands/OfficeFilter';
import '@components/islands/OfficeFilter.css';
import ContactCTA from '@components/ContactCTA.astro';
import { getBuildingBySlug } from '@data/buildings';
import { withBase } from '@utils/withBase';

const building = getBuildingBySlug('fidel')!;

const title = `Аренда офисов в бизнес-лофте ${building.name} — свободные помещения | АНМ`;
const description = `Аренда офисов в бизнес-лофте ${building.name}. Класс B+, дизайнерская отделка в стиле лофт, от 45 до 200 м². Свяжитесь с нами для обсуждения вариантов.`;

const typicalOffices = [
  {
    label: 'Пример типового офиса в бизнес-лофте Фидель',
    planImage: withBase('/plans/fidel plan example.png'),
    area: 'от 45 до 200 м²',
    buildingClass: 'B+',
    type: 'Кабинет / Open Space',
    pricePerSqm: 'от 1 050 ₽/м²',
    href: withBase('/buildings/fidel/'),
  },
];
---

<BuildingLayout
  title={title}
  description={description}
  buildingName={building.name}
  buildingSlug={building.slug}
>
  <section class="offices-section">
    <div class="container">
      <h1 class="offices-section__title">Аренда офисов в бизнес-лофте Фидель</h1>

      <OfficeFilter
        client:visible
        buildingSlug="fidel"
        contactPhone="+7 (812) 336-55-64"
        contactEmail="arenda@ukanm.ru"
        typicalOffices={typicalOffices}
        otherBuildingName="БЦ АНМ"
        otherBuildingOfficesUrl={withBase('/buildings/anm/offices/')}
      />
    </div>
  </section>

  <ContactCTA />
</BuildingLayout>

<style>
  .offices-section {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .offices-section__title {
    font-size: var(--text-h1);
    margin-bottom: var(--space-2xl);
  }
</style>
