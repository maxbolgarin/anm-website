---
import BuildingLayout from '@layouts/BuildingLayout.astro';
import OfficeFilter from '@components/islands/OfficeFilter';
import '@components/islands/OfficeFilter.css';
import ContactCTA from '@components/ContactCTA.astro';
import { getBuildingBySlug } from '@data/buildings';

const building = getBuildingBySlug('anm')!;

const title = `Аренда офисов в БЦ ${building.name} — свободные помещения | АНМ`;
const description = `Аренда офиса в бизнес-центре ${building.name}. Класс B, 6 этаж, 100,8 м², кабинетная планировка, свежий ремонт. Прямая аренда от собственника.`;
---

<BuildingLayout
  title={title}
  description={description}
  buildingName={building.name}
  buildingSlug={building.slug}
>
  <section class="offices-section">
    <div class="container">
      <h1 class="offices-section__title">Аренда офисов в БЦ АНМ</h1>

      <OfficeFilter
        client:visible
        buildingSlug="anm"
        contactPhone="+7 (812) 336-55-64"
        contactEmail="arenda@ukanm.ru"
      />
    </div>
  </section>

  <ContactCTA />
</BuildingLayout>

<style>
  .offices-section {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .offices-section__title {
    font-size: var(--text-h1);
    margin-bottom: var(--space-2xl);
  }
</style>
