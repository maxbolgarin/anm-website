---
import BaseLayout from '@layouts/BaseLayout.astro';
import BuildingTabsIsland from '@components/BuildingTabsIsland.astro';
import SectionHeading from '@components/SectionHeading.astro';
import StatsGrid from '@components/StatsGrid.astro';
import InteractiveMapIsland from '@components/InteractiveMapIsland.astro';
import LocationContacts from '@components/LocationContacts.astro';
import SEOKeywords from '@components/SEOKeywords.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { buildings } from '@data/buildings';

const title = 'Аренда офисов в бизнес-центрах Санкт-Петербурга — АНМ';
const description = 'Офисы в аренду в бизнес-центрах класса B+ в Санкт-Петербурге. Рядом с метро, развитая инфраструктура, круглосуточный доступ. АНМ — 20+ лет на рынке.';

const statsData = [
  { value: '21 376 м²', label: 'Под управлением' },
  { value: '2', label: 'Бизнес-центра' },
  { value: '20+', label: 'Лет на рынке' },
  { value: '100+', label: 'Арендаторов' },
  { value: '328', label: 'Машиномест' },
  { value: '24/7', label: 'Охрана и доступ' },
  { value: '11', label: 'Этажей суммарно' },
  { value: '6', label: 'Телеком-операторов' },
];

const advantagesData = [
  { icon: '/advantages/allday.svg', label: 'Круглосуточный доступ к офисам' },
  { icon: '/advantages/light.svg', label: 'Энергосберегающие технологии' },
  { icon: '/advantages/wifi.svg', label: '6 операторов связи на ваш выбор' },
  { icon: '/advantages/gas.svg', label: 'Собственная газовая котельня' },
  { icon: '/advantages/direction (1).svg', label: 'Удобная внутренняя логистика' },
  { icon: '/advantages/secure.svg', label: 'Системы безопасности' },
];

const facilityItems = [
  {
    name: 'Охраняемый паркинг',
    description: 'Охраняемый освещённый паркинг. Гостевые места и абонементы.',
    image: '/images/infrastructure/parking-aerial.jpg',
    imageAlt: 'Паркинг на территории Александро-Невской Мануфактуры',
    icon: '🅿️',
  },
  {
    name: 'Фитнес-студия',
    description: 'Современный тренажёрный зал. Специальные условия для арендаторов.',
    image: '/images/infrastructure/fitness-studio.jpg',
    imageAlt: 'Фитнес-студия на территории бизнес-центра',
    icon: '💪',
  },
  {
    name: 'Столовые и кафе',
    description: '2 столовые с комплексными обедами от 250₽ и 2 кафе со свежим кофе, выпечкой и лёгкими перекусами.',
    image: '/images/buildings/anm/abk-cafe-new.jpg',
    imageAlt: 'Кафе на территории Александро-Невской Мануфактуры',
    icon: '🍽',
  },
];

const mapMarkers = buildings.map((b) => ({
  lat: b.coordinates.lat,
  lng: b.coordinates.lng,
  title: `БЦ ${b.name}`,
  address: b.shortAddress,
  link: `/buildings/${b.slug}/`,
}));
---

<BaseLayout title={title} description={description}>

  <!-- ===== SECTION 1: HERO TITLE ===== -->
  <section class="hero-title">
    <div class="hero-title__overlay"></div>
    <div class="container hero-title__content">
      <h1 class="hero-title__heading">
        Аренда офисов<br>в&nbsp;бизнес-центрах Санкт&#8209;Петербурга
      </h1>
      <p class="hero-title__subtitle">
        Александро-Невская Мануфактура&nbsp;—<br>два бизнес-центра на исторической территории у&nbsp;набережной Невы
      </p>
    </div>
  </section>

  <!-- ===== SECTION 2: BUILDING TABS ===== -->
  <section class="section" id="buildings">
    <div class="container">
      <BuildingTabsIsland />
    </div>
  </section>

  <!-- ===== SECTION 3: INFRASTRUCTURE ===== -->
  <section class="section section--cream" id="infrastructure">
    <div class="container">
      <div class="infra-header">
        <span class="infra-header__label">Life-Work Balance</span>
        <h2 class="infra-header__title">Всё необходимое на территории</h2>
        <p class="infra-header__subtitle">
          Вашим сотрудникам не нужно выходить за территорию. Питание, спорт, парковка — всё в шаговой доступности.
        </p>
      </div>
      <div class="infra-grid">
        {facilityItems.map((item) => (
          <div class="infra-card">
            <div class="infra-card__image-wrap">
              <img src={item.image} alt={item.imageAlt} class="infra-card__image" loading="lazy" />
              <span class="infra-card__icon">{item.icon}</span>
            </div>
            <div class="infra-card__content">
              <h3 class="infra-card__name">{item.name}</h3>
              <p class="infra-card__desc">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      <h3 class="infra-header__subtitle infra-header__subtitle--advantages">Почему выбирают нас</h3>
      <div class="advantages__grid">
        {advantagesData.map((adv) => (
          <div class="advantages__item">
            <div class="advantages__icon-wrapper">
              <img src={adv.icon} alt={adv.label} class="advantages__icon" loading="lazy" />
            </div>
            <span class="advantages__label">{adv.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SECTION 5: INTERACTIVE MAP ===== -->
  <section class="section" id="map">
    <div class="container">
      <SectionHeading
        title="Территория"
        subtitle="Бизнес-центры на территории Александро-Невской Мануфактуры"
      />
    </div>
    <div class="map-section">
      <InteractiveMapIsland
        markers={mapMarkers}
        center={{ lat: 59.9076, lng: 30.4270 }}
        zoom={16}
        height="500px"
      />
    </div>
    <div class="container">
      <div class="map-section__cta">
        <a href="/about/#territory" class="btn btn--link">Подробнее о территории и инфраструктуре →</a>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 6: CONTACTS + LOCATION ===== -->
  <LocationContacts />

  <!-- ===== SECTION 7: SEO KEYWORD LINKS ===== -->
  <SEOKeywords />

  <!-- ===== SECTION 8: CONTACT CTA ===== -->
  <ContactCTA />

  <!-- ===== SECTION 9: DISCLOSURE ===== -->
  <section class="section disclosure" id="disclosure">
    <div class="container">
      <details class="disclosure__details">
        <summary class="disclosure__summary">Раскрытие информации</summary>
        <div class="disclosure__content">
          <p>Информация, подлежащая раскрытию в соответствии с законодательством Российской Федерации. <a href="/legal/">Полная информация</a></p>
        </div>
      </details>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero Title */
  .hero-title {
    position: relative;
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-5xl);
    background-image: url('/images/common/territory-aerial-hero.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
  }

  .hero-title__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0.15) 100%
    );
  }

  .hero-title__content {
    position: relative;
    z-index: 1;
  }

  .hero-title__heading {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: 1.15;
    margin-bottom: var(--space-lg);
    max-width: 38rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .hero-title__subtitle {
    font-size: var(--text-h4);
    color: rgba(255, 255, 255, 0.85);
    max-width: 36rem;
    line-height: var(--leading-relaxed);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  }

  /* Infrastructure header */
  .infra-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .infra-header__label {
    display: inline-block;
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .infra-header__title {
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-md);
  }

  .infra-header__subtitle {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin-inline: auto;
    line-height: var(--leading-relaxed);
  }

  /* Infrastructure grid — 3 columns */
  .infra-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  /* Infrastructure card */
  .infra-card {
    border-radius: var(--radius-md);
    overflow: hidden;
    background-color: var(--color-surface-white);
    border: none;
    transition: box-shadow var(--transition-base);
  }

  .infra-card:hover {
    box-shadow: var(--shadow-md);
  }

  .infra-card__image-wrap {
    position: relative;
    overflow: hidden;
  }

  .infra-card__image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .infra-card:hover .infra-card__image {
    transform: scale(1.03);
  }

  .infra-card__icon {
    position: absolute;
    bottom: var(--space-md);
    left: var(--space-md);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-surface-white);
    border-radius: var(--radius-sm);
    font-size: 1.25rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }

  .infra-card__content {
    padding: var(--space-lg);
  }

  .infra-card__name {
    font-size: var(--text-h4);
    margin-bottom: var(--space-sm);
  }

  .infra-card__desc {
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* Advantages subtitle */
  .infra-header__subtitle--advantages {
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  /* Advantages grid */
  .advantages__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-xl) var(--space-lg);
  }

  .advantages__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-xs);
    transition: transform 0.2s ease;
  }

  .advantages__item:hover {
    transform: translateY(-4px);
  }

  .advantages__icon-wrapper {
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: transparent;
    border: 2px solid var(--color-primary);
    flex-shrink: 0;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .advantages__item:hover .advantages__icon-wrapper {
    background-color: rgba(183, 28, 28, 0.04);
    border-color: var(--color-primary-dark);
  }

  .advantages__icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .advantages__label {
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    max-width: 140px;
  }

  @media (max-width: 1023px) {
    .advantages__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }

    .advantages__icon-wrapper {
      width: 80px;
      height: 80px;
    }

    .advantages__icon {
      width: 40px;
      height: 40px;
    }
  }

  @media (max-width: 767px) {
    .advantages__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }

    .advantages__icon-wrapper {
      width: 64px;
      height: 64px;
    }

    .advantages__icon {
      width: 32px;
      height: 32px;
    }
  }

  /* Map */
  .map-section {
    width: 100%;
    height: 500px;
    background-color: var(--color-surface-cream);
  }

  .map-section__cta {
    padding-top: var(--space-lg);
    text-align: center;
  }

  /* Disclosure */
  .disclosure {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .disclosure__summary {
    cursor: pointer;
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    font-size: var(--text-caption);
  }

  .disclosure__content {
    margin-top: var(--space-md);
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
  }

  @media (max-width: 1023px) {
    .infra-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .hero-title {
      padding-top: var(--space-3xl);
      padding-bottom: var(--space-3xl);
      min-height: 40vh;
    }

    .map-section {
      height: 350px;
    }

    .infra-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
