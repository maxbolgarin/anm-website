---
import BaseLayout from '@layouts/BaseLayout.astro';
import BuildingTabsIsland from '@components/BuildingTabsIsland.astro';
import SectionHeading from '@components/SectionHeading.astro';
import StatsGrid from '@components/StatsGrid.astro';
import TerritoryMapIsland from '@components/TerritoryMapIsland.astro';
import LocationContacts from '@components/LocationContacts.astro';
import SEOKeywords from '@components/SEOKeywords.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { buildings } from '@data/buildings';
import { withBase } from '@utils/withBase';

const title = 'Аренда офисов в бизнес-центрах Санкт-Петербурга — АНМ';
const description = 'Офисы в аренду в бизнес-центрах класса B+ в Санкт-Петербурге. Рядом с метро, развитая инфраструктура, круглосуточный доступ. АНМ — 20+ лет на рынке.';

const statsData = [
  { value: '21 376 м²', label: 'Под управлением' },
  { value: '2', label: 'Бизнес-центра' },
  { value: '20+', label: 'Лет на рынке' },
  { value: '80+', label: 'Арендаторов' },
  { value: '328', label: 'Машиномест' },
  { value: '24/7', label: 'Охрана и доступ' },
  { value: '11', label: 'Этажей суммарно' },
  { value: '6', label: 'Телеком-операторов' },
];

const advantagesData = [
  { icon: '/advantages/allday.svg', label: 'Круглосуточный доступ к офисам' },
  { icon: '/advantages/light.svg', label: 'Энергосберегающие технологии' },
  { icon: '/advantages/wifi.svg', label: '6 операторов связи на выбор' },
  { icon: '/advantages/gas.svg', label: 'Собственная газовая котельня' },
  { icon: '/advantages/direction (1).svg', label: 'Внутренняя логистика' },
  { icon: '/advantages/secure.svg', label: 'Системы безопасности' },
];

const advantagesDataWithBase = advantagesData.map((item) => ({
  ...item,
  icon: withBase(item.icon),
}));

const facilityItems = [
  {
    name: 'Охраняемый паркинг',
    description: 'Охраняемый освещённый паркинг. Гостевые места и абонементы.',
    image: '/images/infrastructure/parking-aerial.jpg',
    imageAlt: 'Паркинг на территории Александро-Невской Мануфактуры',
    icon: '🅿️',
  },
  {
    name: 'Фитнес-студия',
    description: 'Современный тренажёрный зал. Специальные условия для арендаторов.',
    image: '/фото бц/image_2026-04-23_13-54-55 (1).png',
    imageAlt: 'Фитнес-студия на территории бизнес-центра',
    icon: '💪',
  },
  {
    name: 'Столовые и кафе',
    description: '2 столовые с комплексными обедами, 2 кафе со свежим кофе и лёгкими перекусами.',
    image: '/images/buildings/anm/abk-cafe-new.jpg',
    imageAlt: 'Кафе на территории Александро-Невской Мануфактуры',
    icon: '🍽',
  },
];

const facilityItemsWithBase = facilityItems.map((item) => ({
  ...item,
  image: withBase(item.image),
}));

const heroBackgroundImage = withBase('/images/common/territory-aerial-hero.png');
const heroVideo = withBase('/territory/3D_Isometric_Map_An_aerial_drone_shot_pans_across_a_city_skyline.mp4');

---

<BaseLayout title={title} description={description}>

  <!-- ===== SECTION 1: HERO TITLE ===== -->
  <section class="hero-title" id="hero" style={`--bg-fallback: url('${heroBackgroundImage}')`}>
    <canvas class="hero-title__canvas" id="hero-canvas"></canvas>
    <div class="hero-title__overlay"></div>
    <div class="container hero-title__content">
      <span class="hero-title__eyebrow">С&nbsp;2004 · Санкт&#8209;Петербург</span>
      <h1 class="hero-title__heading">
        Александро&#8209;Невская<br />Мануфактура
      </h1>
      <p class="hero-title__subtitle">
        Бизнес&#8209;кластер на&nbsp;исторической набережной Невы
      </p>
    </div>
  </section>

  <script define:vars={{ heroVideo, heroBackgroundImage }}>
    (function() {
    function init() {
      const hero = document.getElementById('hero');
      const canvas = document.getElementById('hero-canvas');
      if (!hero || !canvas) return;

      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      // Check connection quality — skip video on slow connections
      const conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
      const isSlowConnection = conn && (
        conn.saveData ||
        conn.effectiveType === 'slow-2g' ||
        conn.effectiveType === '2g' ||
        conn.effectiveType === '3g'
      );

      const isMobile = window.innerWidth < 768;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // On slow connections: remove canvas so the CSS fallback image shows
      if (isSlowConnection) {
        canvas.remove();
        return;
      }

      const frames = [];
      let totalFrames = 0;
      let ready = false;
      let firstFrameDrawn = false;
      let currentFrameIndex = 0;
      const FPS = 30;

      if (isMobile || prefersReducedMotion) {
        const vid = document.createElement('video');
        vid.src = heroVideo;
        vid.muted = true;
        vid.playsInline = true;
        vid.loop = true;
        vid.autoplay = true;
        vid.className = 'hero-title__canvas';
        vid.style.objectFit = 'cover';
        // Keep canvas hidden until video can play — fallback image shows underneath
        vid.style.opacity = '0';
        vid.style.transition = 'opacity 0.5s ease';
        canvas.replaceWith(vid);
        vid.addEventListener('canplay', () => { vid.style.opacity = '1'; }, { once: true });
        vid.play().catch(() => { vid.remove(); });
        return;
      }

      function resizeCanvas() {
        const dpr = window.devicePixelRatio || 1;
        canvas.width = hero.offsetWidth * dpr;
        canvas.height = hero.offsetHeight * dpr;
        ctx.scale(dpr, dpr);
        canvas.style.width = hero.offsetWidth + 'px';
        canvas.style.height = hero.offsetHeight + 'px';
        if (ready && frames[currentFrameIndex]) {
          drawFrame(currentFrameIndex);
        }
      }

      function drawFrame(index) {
        if (!frames[index]) return;
        const cw = hero.offsetWidth;
        const ch = hero.offsetHeight;
        const img = frames[index];
        const imgRatio = img.width / img.height;
        const canvasRatio = cw / ch;
        let sw, sh, sx, sy;
        if (imgRatio > canvasRatio) {
          sh = img.height;
          sw = img.height * canvasRatio;
          sx = (img.width - sw) / 2;
          sy = 0;
        } else {
          sw = img.width;
          sh = img.width / canvasRatio;
          sx = 0;
          sy = (img.height - sh) / 2;
        }
        ctx.drawImage(img, sx, sy, sw, sh, 0, 0, cw, ch);
        currentFrameIndex = index;
        // Fade canvas in once first frame is drawn
        if (!firstFrameDrawn) {
          firstFrameDrawn = true;
          canvas.style.opacity = '1';
        }
      }

      function getScrollProgress() {
        const rect = hero.getBoundingClientRect();
        const heroHeight = hero.offsetHeight;
        const scrolled = heroHeight - rect.bottom + window.innerHeight;
        const totalRange = heroHeight + window.innerHeight;
        return Math.min(Math.max(scrolled / totalRange, 0), 1);
      }

      function extractFrames() {
        return new Promise((resolve, reject) => {
          const video = document.createElement('video');
          video.src = heroVideo;
          video.muted = true;
          video.playsInline = true;
          video.preload = 'auto';

          // Timeout: if video metadata doesn't load in 8s, give up
          const timeout = setTimeout(() => {
            video.src = '';
            reject(new Error('timeout'));
          }, 8000);

          video.addEventListener('error', () => {
            clearTimeout(timeout);
            reject(new Error('video-error'));
          });

          video.addEventListener('loadedmetadata', () => {
            clearTimeout(timeout);
            const duration = video.duration;
            totalFrames = Math.ceil(duration * FPS);
            const tempCanvas = document.createElement('canvas');
            tempCanvas.width = video.videoWidth;
            tempCanvas.height = video.videoHeight;
            const tempCtx = tempCanvas.getContext('2d');
            let frameIndex = 0;

            function captureFrame() {
              if (frameIndex >= totalFrames) {
                resolve(frames);
                return;
              }
              const time = (frameIndex / totalFrames) * duration;
              video.currentTime = time;
            }

            video.addEventListener('seeked', () => {
              tempCtx.drawImage(video, 0, 0, tempCanvas.width, tempCanvas.height);
              createImageBitmap(tempCanvas).then((bitmap) => {
                frames[frameIndex] = bitmap;

                if (frameIndex === 0) {
                  resizeCanvas();
                  drawFrame(0);
                }

                frameIndex++;
                captureFrame();
              });
            });

            captureFrame();
          });
        });
      }

      extractFrames().then(() => {
        ready = true;
        const progress = getScrollProgress();
        const index = Math.min(Math.round(progress * (totalFrames - 1)), totalFrames - 1);
        drawFrame(index);
      }).catch(() => {
        // Video failed or timed out — remove canvas, static fallback image shows
        canvas.remove();
      });

      window.addEventListener('scroll', () => {
        if (!ready) return;
        requestAnimationFrame(() => {
          const progress = getScrollProgress();
          const index = Math.min(Math.round(progress * (totalFrames - 1)), totalFrames - 1);
          if (index !== currentFrameIndex) {
            drawFrame(index);
          }
        });
      }, { passive: true });

      window.addEventListener('resize', resizeCanvas);
      resizeCanvas();
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    })();
  </script>

  <!-- ===== SECTION 2: BUILDING TABS ===== -->
  <section class="section" id="buildings">
    <div class="container">
      <BuildingTabsIsland />
    </div>
  </section>

  <!-- ===== SECTION 3: INFRASTRUCTURE ===== -->
  <section class="section section--cream" id="infrastructure">
    <div class="container">
      <div class="infra-header">

        <h2 class="infra-header__title">Всё необходимое на территории</h2>
        <p class="infra-header__subtitle">
          Вашим сотрудникам не нужно выходить за территорию. Питание, спорт, парковка — всё в шаговой доступности.
        </p>
      </div>
      <div class="infra-grid">
        {facilityItemsWithBase.map((item) => (
          <div class="infra-card">
            <div class="infra-card__image-wrap">
              <img src={item.image} alt={item.imageAlt} class="infra-card__image" loading="lazy" />
              <span class="infra-card__icon">{item.icon}</span>
            </div>
            <div class="infra-card__content">
              <h3 class="infra-card__name">{item.name}</h3>
              <p class="infra-card__desc">{item.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="advantages__grid">
        {advantagesDataWithBase.map((adv) => (
          <div class="advantages__item">
            <div class="advantages__icon-wrapper">
              <img src={adv.icon} alt={adv.label} class="advantages__icon" loading="lazy" />
            </div>
            <span class="advantages__label">{adv.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SECTION 5: TERRITORY MAP ===== -->
  <section class="section" id="territory-map">
    <div class="container">
      <SectionHeading
        title="Территория"
        subtitle="Инфраструктура бизнес-центров Александро-Невской Мануфактуры"
      />
      <TerritoryMapIsland />
      <div class="map-section__cta">
        <a href={withBase('/territory/')} class="btn btn--link">Подробнее о локации →</a>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 6: CONTACTS + LOCATION ===== -->
  <LocationContacts />

  <!-- ===== SECTION 7: SEO KEYWORD LINKS ===== -->
  <SEOKeywords />

  <!-- ===== SECTION 8: CONTACT CTA ===== -->
  <ContactCTA />

  <!-- ===== SECTION 9: DISCLOSURE ===== -->
  <section class="section disclosure" id="disclosure">
    <div class="container">
      <details class="disclosure__details">
        <summary class="disclosure__summary">Раскрытие информации</summary>
        <div class="disclosure__content">
          <p>Информация, подлежащая раскрытию в соответствии с законодательством Российской Федерации. <a href={withBase('/legal/')}>Полная информация</a></p>
        </div>
      </details>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero Title */
  .hero-title {
    position: relative;
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-3xl);
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    /* Fallback for when video doesn't load */
    background-image: var(--bg-fallback);
    background-size: cover;
    background-position: center;
  }

  .hero-title__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .hero-title__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0.15) 100%
    );
  }

  .hero-title__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .hero-title__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--color-gold);
    margin-bottom: var(--space-md);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.45);
  }

  .hero-title__heading {
    font-family: var(--font-heading);
    font-size: var(--text-display);
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: 1.02;
    letter-spacing: -0.015em;
    margin-bottom: var(--space-lg);
    max-width: 22ch;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  }

  .hero-title__subtitle {
    font-size: var(--text-body);
    color: rgba(255, 255, 255, 0.88);
    max-width: none;
    line-height: var(--leading-relaxed);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  }

  /* Infrastructure header */
  .infra-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .infra-header__label {
    display: inline-block;
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-sm);
  }

  .infra-header__title {
    font-size: var(--text-h1);
    margin-bottom: var(--space-md);
  }

  .infra-header__subtitle {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    max-width: 36rem;
    margin-inline: auto;
    line-height: var(--leading-relaxed);
  }

  /* Infrastructure grid — 3 columns */
  .infra-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  /* Infrastructure card — image with overlaid text */
  .infra-card {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    background-color: var(--color-text-primary);
    border: none;
    border-bottom: 3px solid var(--color-primary);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition: box-shadow var(--transition-base);
    isolation: isolate;
  }

  .infra-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.14);
  }

  .infra-card__image-wrap {
    position: relative;
    overflow: hidden;
  }

  .infra-card__image-wrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.45) 22%,
      rgba(0, 0, 0, 0.10) 45%,
      transparent 60%
    );
    pointer-events: none;
    z-index: 1;
  }

  .infra-card__image {
    display: block;
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .infra-card:hover .infra-card__image {
    transform: scale(1.03);
  }

  .infra-card__icon {
    display: none;
  }

  .infra-card__content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: var(--space-md) var(--space-lg) var(--space-sm);
    color: var(--color-text-inverse);
  }

  .infra-card__name {
    font-size: var(--text-body);
    color: var(--color-text-inverse);
    margin-bottom: var(--space-xs);
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.35);
  }

  .infra-card__desc {
    font-size: var(--text-caption);
    color: rgba(255, 255, 255, 0.90);
    line-height: var(--leading-relaxed);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  }

  /* Advantages grid */
  .advantages__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-xl) var(--space-lg);
    margin-top: var(--space-3xl);
  }

  .advantages__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-xs);
    transition: transform 0.2s ease;
  }

  .advantages__item:hover {
    transform: translateY(-4px);
  }

  .advantages__icon-wrapper {
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: transparent;
    border: 2px solid var(--color-primary);
    flex-shrink: 0;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .advantages__item:hover .advantages__icon-wrapper {
    background-color: rgba(183, 28, 28, 0.04);
    border-color: var(--color-primary-dark);
  }

  .advantages__icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .advantages__label {
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    max-width: 140px;
  }

  @media (max-width: 1023px) {
    .advantages__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }

    .advantages__icon-wrapper {
      width: 80px;
      height: 80px;
    }

    .advantages__icon {
      width: 40px;
      height: 40px;
    }
  }

  @media (max-width: 767px) {
    .advantages__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }

    .advantages__icon-wrapper {
      width: 64px;
      height: 64px;
    }

    .advantages__icon {
      width: 32px;
      height: 32px;
    }
  }

  /* Map */
  .map-section {
    width: 100%;
    height: 500px;
    background-color: var(--color-surface-cream);
  }

  .map-section__cta {
    padding-top: var(--space-lg);
    text-align: center;
  }

  /* Disclosure */
  .disclosure {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .disclosure__summary {
    cursor: pointer;
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    font-size: var(--text-caption);
  }

  .disclosure__content {
    margin-top: var(--space-md);
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
  }

  @media (max-width: 1023px) {
    .infra-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .hero-title {
      padding-top: var(--space-3xl);
      padding-bottom: var(--space-3xl);
      min-height: 40vh;
    }


    .map-section {
      height: 350px;
    }

    .infra-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
