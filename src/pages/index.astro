---
import BaseLayout from '@layouts/BaseLayout.astro';
import BuildingTabsIsland from '@components/BuildingTabsIsland.astro';
import SectionHeading from '@components/SectionHeading.astro';
import StatsGrid from '@components/StatsGrid.astro';
import InteractiveMapIsland from '@components/InteractiveMapIsland.astro';
import LocationContacts from '@components/LocationContacts.astro';
import SEOKeywords from '@components/SEOKeywords.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { buildings } from '@data/buildings';

const title = 'Аренда офисов в бизнес-центрах Санкт-Петербурга — УК АНМ';
const description = 'Офисы в аренду в бизнес-центрах класса B+ в Санкт-Петербурге. Рядом с метро, развитая инфраструктура, круглосуточный доступ. УК АНМ — 15+ лет на рынке.';

const statsData = [
  { value: '22 000 м²', label: 'Под управлением' },
  { value: '2', label: 'Бизнес-центра' },
  { value: '15+', label: 'Лет на рынке' },
  { value: '100+', label: 'Арендаторов' },
  { value: '500', label: 'Машиномест' },
  { value: '24/7', label: 'Охрана и доступ' },
  { value: '9', label: 'Этажей суммарно' },
  { value: '6', label: 'Телеком-операторов' },
];

const mapMarkers = buildings.map((b) => ({
  lat: b.coordinates.lat,
  lng: b.coordinates.lng,
  title: `БЦ ${b.name}`,
  address: b.shortAddress,
  link: `/buildings/${b.slug}/`,
}));
---

<BaseLayout title={title} description={description}>

  <!-- ===== SECTION 1: HERO TITLE ===== -->
  <section class="hero-title">
    <div class="hero-title__overlay"></div>
    <div class="container hero-title__content">
      <h1 class="hero-title__heading">
        Аренда офисов<br>в&nbsp;бизнес-центрах Санкт&#8209;Петербурга
      </h1>
      <p class="hero-title__subtitle">
        УК Александро-Невская Мануфактура&nbsp;—<br>два бизнес-центра на исторической территории у&nbsp;набережной Невы
      </p>
    </div>
  </section>

  <!-- ===== SECTION 2: BUILDING TABS ===== -->
  <section class="section" id="buildings">
    <div class="container">
      <BuildingTabsIsland />
    </div>
  </section>

  <!-- ===== SECTION 3: STATS "ПОЧЕМУ У НАС" ===== -->
  <StatsGrid
    title="Почему выбирают нас"
    subtitle="Цифры, которые говорят сами за себя"
    stats={statsData}
  />

  <!-- ===== SECTION 5: INTERACTIVE MAP ===== -->
  <section class="section" id="map">
    <div class="container">
      <SectionHeading
        title="Территория"
        subtitle="Бизнес-центры на территории Александро-Невской Мануфактуры"
      />
    </div>
    <div class="map-section">
      <InteractiveMapIsland
        markers={mapMarkers}
        center={{ lat: 59.9076, lng: 30.4270 }}
        zoom={16}
        height="500px"
      />
    </div>
    <div class="container">
      <div class="map-section__cta">
        <a href="/about/#territory" class="btn btn--link">Подробнее о территории и инфраструктуре →</a>
      </div>
    </div>
  </section>

  <!-- ===== SECTION 6: CONTACTS + LOCATION ===== -->
  <LocationContacts />

  <!-- ===== SECTION 7: SEO KEYWORD LINKS ===== -->
  <SEOKeywords />

  <!-- ===== SECTION 8: CONTACT CTA ===== -->
  <ContactCTA />

  <!-- ===== SECTION 9: DISCLOSURE ===== -->
  <section class="section disclosure" id="disclosure">
    <div class="container">
      <details class="disclosure__details">
        <summary class="disclosure__summary">Раскрытие информации</summary>
        <div class="disclosure__content">
          <p>Информация, подлежащая раскрытию в соответствии с законодательством Российской Федерации. <a href="/legal/">Полная информация</a></p>
        </div>
      </details>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero Title */
  .hero-title {
    position: relative;
    padding-top: var(--space-5xl);
    padding-bottom: var(--space-5xl);
    background-image: url('/images/common/territory-aerial-hero.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
  }

  .hero-title__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0.15) 100%
    );
  }

  .hero-title__content {
    position: relative;
    z-index: 1;
  }

  .hero-title__heading {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: var(--weight-bold);
    color: #fff;
    line-height: 1.15;
    margin-bottom: var(--space-lg);
    max-width: 38rem;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .hero-title__subtitle {
    font-size: var(--text-h4);
    color: rgba(255, 255, 255, 0.85);
    max-width: 36rem;
    line-height: var(--leading-relaxed);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  }

  /* Map */
  .map-section {
    width: 100%;
    height: 500px;
    background-color: var(--color-surface-cream);
  }

  .map-section__cta {
    padding-top: var(--space-lg);
    text-align: center;
  }

  /* Disclosure */
  .disclosure {
    padding-block: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .disclosure__summary {
    cursor: pointer;
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    font-size: var(--text-caption);
  }

  .disclosure__content {
    margin-top: var(--space-md);
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
  }

  @media (max-width: 767px) {
    .hero-title {
      padding-top: var(--space-3xl);
      padding-bottom: var(--space-3xl);
      min-height: 40vh;
    }

    .map-section {
      height: 350px;
    }
  }
</style>
