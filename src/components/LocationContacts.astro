---
import { contactInfo } from '@data/navigation';
import { buildings } from '@data/buildings';
import { getLocaleFromPath } from '@utils/locale';
import { getBuildingEnBySlug } from '@data/buildings-en';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const isEn = locale === 'en';

const routeLinks = buildings.map((b) => {
  const en = getBuildingEnBySlug(b.slug);
  return {
    name: isEn && en ? en.name : b.name,
    twogis: `https://2gis.ru/spb/directions/points/~${b.coordinates.lng},${b.coordinates.lat}`,
    yandex: `https://yandex.ru/maps/?rtext=~${b.coordinates.lat},${b.coordinates.lng}&rtt=auto`,
  };
});
---

<section class="location-contacts section">
  <div class="container">
    <div class="location-contacts__grid">
      <div class="location-contacts__contacts">
        <h2 class="location-contacts__heading">{isEn ? 'Contacts' : 'Контакты'}</h2>
        <div class="location-contacts__items">
          <div class="location-contacts__item">
            <span class="location-contacts__label">{isEn ? 'Main phone' : 'Основной телефон'}</span>
            <a href={contactInfo.phoneHref} class="location-contacts__value location-contacts__value--phone">
              {contactInfo.phone}
            </a>
          </div>
          <div class="location-contacts__item">
            <span class="location-contacts__label">{isEn ? 'Commercial Dept.' : 'Коммерческий отдел'}</span>
            <a href={contactInfo.commercialHref} class="location-contacts__value">
              {contactInfo.commercial}
            </a>
          </div>
          <div class="location-contacts__item">
            <span class="location-contacts__label">{isEn ? 'Reception' : 'Приемная'}</span>
            <a href={contactInfo.receptionHref} class="location-contacts__value">
              {contactInfo.reception}
            </a>
          </div>
          <div class="location-contacts__item">
            <span class="location-contacts__label">Email</span>
            <a href={contactInfo.emailHref} class="location-contacts__value">
              {contactInfo.email}
            </a>
          </div>
        </div>
      </div>

      <div class="location-contacts__location">
        <h2 class="location-contacts__heading">{isEn ? 'How to Get Here' : 'Как доехать'}</h2>
        <div class="location-contacts__metro">
          <span class="location-contacts__metro-dot" style="background-color: #009A49;"></span>
          <span class="location-contacts__metro-name">{isEn ? 'Elizarovskaya metro' : 'м. Елизаровская'}</span>
          <span class="location-contacts__metro-time">{isEn ? '9 min walk' : '9 мин пешком'}</span>
        </div>
        <p class="location-contacts__address">
          {isEn ? 'Saint Petersburg, Obukhovskoy Oborony Ave. 70, Bldg. 2, Lit. A' : contactInfo.address}
        </p>
        <p class="location-contacts__directions">
          {isEn
            ? 'Aleksandro-Nevskaya Manufaktura is located on the Neva River embankment, a 9-minute walk from Elizarovskaya metro station (green line). Convenient access from Obukhovskoy Oborony Ave.'
            : 'Территория Александро-Невской Мануфактуры расположена на набережной реки Невы, в 9 минутах ходьбы от станции метро Елизаровская (зелёная линия). Удобный подъезд с\u00a0Пр.\u00a0Обуховской\u00a0Обороны.'}
        </p>
        <div class="location-contacts__routes">
          {routeLinks.map((r) => (
            <div class="route-group">
              <span class="route-group__label">{isEn ? `Route to BC ${r.name}` : `Маршрут до ${r.name.startsWith('БЦ') ? r.name : `БЦ ${r.name}`}`}</span>
              <div class="route-group__buttons">
                <a href={r.twogis} target="_blank" rel="noopener noreferrer" class="route-btn route-btn--2gis">
                  <svg class="route-btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  2GIS
                </a>
                <a href={r.yandex} target="_blank" rel="noopener noreferrer" class="route-btn route-btn--yandex">
                  <svg class="route-btn__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="3 11 22 2 13 21 11 13 3 11"/>
                  </svg>
                  {isEn ? 'Yandex Maps' : 'Яндекс Карты'}
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .location-contacts__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
  }

  .location-contacts__heading {
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-xl);
  }

  .location-contacts__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .location-contacts__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .location-contacts__label {
    font-size: var(--text-small);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .location-contacts__value {
    font-size: var(--text-body);
    color: var(--color-text-primary);
    font-weight: var(--weight-medium);
    transition: color var(--transition-fast);
  }

  .location-contacts__value:hover {
    color: var(--color-primary);
  }

  .location-contacts__value--phone {
    font-size: var(--text-body);
    font-weight: var(--weight-bold);
  }

  .location-contacts__metro {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-surface-cream);
    border-radius: var(--radius-md);
  }

  .location-contacts__metro-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .location-contacts__metro-name {
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
  }

  .location-contacts__metro-time {
    color: var(--color-text-secondary);
    font-size: var(--text-caption);
  }

  .location-contacts__address {
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    margin-bottom: var(--space-md);
  }

  .location-contacts__directions {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-lg);
  }

  .location-contacts__routes {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .route-group__label {
    display: block;
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .route-group__buttons {
    display: flex;
    gap: var(--space-sm);
  }

  .route-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-sm);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    transition: background-color var(--transition-fast), color var(--transition-fast);
    text-decoration: none;
    border: 1px solid var(--color-border);
  }

  .route-btn__icon {
    flex-shrink: 0;
  }

  .route-btn--2gis {
    color: #1a7640;
    background-color: #e8f5ee;
    border-color: #c3e6d1;
  }

  .route-btn--2gis:hover {
    background-color: #1a7640;
    color: #ffffff;
    border-color: #1a7640;
  }

  .route-btn--yandex {
    color: #cc0000;
    background-color: #fff3f3;
    border-color: #ffd6d6;
  }

  .route-btn--yandex:hover {
    background-color: #cc0000;
    color: #ffffff;
    border-color: #cc0000;
  }

  @media (max-width: 767px) {
    .location-contacts__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }
</style>
