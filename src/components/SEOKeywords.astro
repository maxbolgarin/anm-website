---
import { withBase } from '@utils/withBase';
import { getLocaleFromPath } from '@utils/locale';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const isEn = locale === 'en';

const keywordsRu = [
  { label: 'Офисы у м. Елизаровская', href: '/buildings/' },
  { label: 'Офисы в Невском районе', href: '/buildings/' },
  { label: 'Лофт-офисы СПб', href: '/buildings/fidel/' },
  { label: 'Офисы 50–100 м²', href: '/buildings/' },
  { label: 'Офисы 100–300 м²', href: '/buildings/' },
  { label: 'Офисы 300+ м²', href: '/buildings/' },
  { label: 'Аренда офисов класса B+', href: '/buildings/' },
  { label: 'Офисы с паркингом', href: '/buildings/' },
];

const keywordsEn = [
  { label: 'Offices near Elizarovskaya metro', href: '/en/buildings/' },
  { label: 'Offices in Nevsky district', href: '/en/buildings/' },
  { label: 'Loft offices SPb', href: '/en/buildings/fidel/' },
  { label: 'Offices 50–100 m²', href: '/en/buildings/' },
  { label: 'Offices 100–300 m²', href: '/en/buildings/' },
  { label: 'Offices 300+ m²', href: '/en/buildings/' },
  { label: 'Class B+ office rental', href: '/en/buildings/' },
  { label: 'Offices with parking', href: '/en/buildings/' },
];

const keywords = isEn ? keywordsEn : keywordsRu;
---

<section class="seo-keywords" aria-hidden="true">
  <div class="container">
    <div class="seo-keywords__list">
      {keywords.map((kw) => (
        <a href={withBase(kw.href)} class="seo-keywords__pill" tabindex="-1">
          {kw.label}
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .seo-keywords {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
