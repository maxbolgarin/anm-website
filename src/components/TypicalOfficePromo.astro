---
import { withBase } from '@utils/withBase';
import { getLocaleFromPath } from '@utils/locale';

interface Props {
  buildingName: string;
  buildingLabel: string;
  planImage: string;
  area: string;
  buildingClass: string;
  type: string;
  pricePerSqm: string;
  href: string;
}

const { buildingName, buildingLabel, planImage, area, buildingClass, type, pricePerSqm, href } = Astro.props;
const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const isEn = locale === 'en';
---

<section class="typical-promo">
  <div class="container">
    <div class="typical-promo__card">
      <div class="typical-promo__image-wrap">
        <img src={withBase(planImage)} alt={`${isEn ? 'Typical office' : 'Типовой офис'} — ${buildingName}`} class="typical-promo__image" />
      </div>
      <div class="typical-promo__content">
        <span class="typical-promo__badge">{isEn ? 'Typical Office' : 'Типовой офис'}</span>
        <h3 class="typical-promo__title">{isEn ? `Typical office example in ${buildingLabel}` : `Пример типового офиса в ${buildingLabel}`}</h3>
        <div class="typical-promo__params">
          <div class="typical-promo__param">
            <span class="typical-promo__param-label">{isEn ? 'Area' : 'Площадь'}</span>
            <span class="typical-promo__param-value">{area}</span>
          </div>
          <div class="typical-promo__param">
            <span class="typical-promo__param-label">{isEn ? 'Class' : 'Класс'}</span>
            <span class="typical-promo__param-value">{buildingClass}</span>
          </div>
          <div class="typical-promo__param">
            <span class="typical-promo__param-label">{isEn ? 'Type' : 'Тип'}</span>
            <span class="typical-promo__param-value">{type}</span>
          </div>
          <div class="typical-promo__param">
            <span class="typical-promo__param-label">{isEn ? 'Price' : 'Стоимость'}</span>
            <span class="typical-promo__param-value">{pricePerSqm}</span>
          </div>
        </div>
        <a href={withBase(href)} class="btn btn--primary typical-promo__btn">{isEn ? 'Learn More' : 'Узнать подробнее'}</a>
      </div>
    </div>
  </div>
</section>

<style>
  .typical-promo {
    padding-block: var(--space-3xl);
  }

  .typical-promo__card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background-color: var(--color-surface-cream, #F5F0E8);
    border: 2px solid var(--color-accent-yellow, #F5D45E);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .typical-promo__image-wrap {
    background-color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    border-right: 1px solid rgba(0, 0, 0, 0.06);
  }

  .typical-promo__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    max-height: 18rem;
  }

  .typical-promo__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 2.5rem;
    gap: 1rem;
  }

  .typical-promo__badge {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.25rem 0.75rem;
    font-family: var(--font-body, 'Verdana', 'Geneva', sans-serif);
    font-size: 0.6875rem;
    font-weight: var(--weight-bold, 550);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #8a6d00;
    background-color: rgba(245, 212, 94, 0.3);
    border-radius: 2rem;
  }

  .typical-promo__title {
    font-family: var(--font-heading, 'Verdana', 'Geneva', sans-serif);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: var(--weight-bold, 550);
    color: var(--color-text-primary, #1a1a1a);
    line-height: 1.3;
    margin: 0;
  }

  .typical-promo__params {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem 1.5rem;
  }

  .typical-promo__param {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .typical-promo__param-label {
    font-family: var(--font-body, 'Verdana', 'Geneva', sans-serif);
    font-size: 0.6875rem;
    font-weight: var(--weight-bold, 550);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-secondary, #6b6b6b);
  }

  .typical-promo__param-value {
    font-family: var(--font-heading, 'Verdana', 'Geneva', sans-serif);
    font-size: 0.9375rem;
    font-weight: var(--weight-bold, 550);
    color: var(--color-text-primary, #1a1a1a);
  }

  .typical-promo__btn {
    margin-top: 0.5rem;
    align-self: flex-start;
  }

  @media (max-width: 767px) {
    .typical-promo__card {
      grid-template-columns: 1fr;
    }

    .typical-promo__image-wrap {
      padding: 1.25rem;
      max-height: 14rem;
    }

    .typical-promo__image {
      max-height: 12rem;
    }

    .typical-promo__content {
      padding: 1.5rem;
    }
  }
</style>
