---
import { mainNav, contactInfo } from '@data/navigation';
import { withBase } from '@utils/withBase';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const normalizedCurrentPath = basePath && currentPath.startsWith(basePath)
  ? (currentPath.slice(basePath.length) || '/')
  : currentPath;
---

<header class="header" id="header">
  <div class="header__inner container-wide">
    <a href={withBase('/')} class="header__logo" aria-label="АНМ — Главная">
      <img
        src={withBase('/images/common/logo.svg')}
        alt="Александро-Невская Мануфактура"
        width="200"
        height="40"
        loading="eager"
      />
    </a>

    <nav class="header__nav" aria-label="Основная навигация">
      <ul class="header__nav-list">
        {mainNav.map((item) => (
          <li class:list={['header__nav-item', { 'header__nav-item--has-dropdown': item.children?.length }]}>
            <a
              href={withBase(item.href)}
              class:list={[
                'header__nav-link',
                { 'header__nav-link--active': normalizedCurrentPath === item.href || normalizedCurrentPath.startsWith(item.href.replace(/\/$/, '') + '/') }
              ]}
            >
              {item.label}
              {item.children?.length && (
                <svg class="header__nav-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </a>
            {item.children?.length && (
              <ul class="header__dropdown">
                {item.children.map((child) => (
                  <li>
                    <a
                      href={withBase(child.href)}
                      class:list={[
                        'header__dropdown-link',
                        { 'header__dropdown-link--active': normalizedCurrentPath === child.href }
                      ]}
                    >
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__right">
      <a href={contactInfo.phoneHref} class="header__phone">
        {contactInfo.phone}
      </a>

      <div class="header__lang">
        <a href={withBase('/')} class="header__lang-link header__lang-link--active">RU</a>
        <span class="header__lang-sep">|</span>
        <a href={withBase('/en/')} class="header__lang-link">EN</a>
      </div>

      <button class="header__burger" aria-label="Открыть меню" aria-expanded="false" id="burger-btn">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="header__mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Мобильная навигация">
      <ul class="header__mobile-list">
        {mainNav.map((item) => (
          <li class="header__mobile-item">
            {item.children?.length ? (
              <details class="header__mobile-details">
                <summary class="header__mobile-link header__mobile-link--parent">
                  {item.label}
                  <svg class="header__mobile-arrow" width="12" height="7" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </summary>
                <ul class="header__mobile-sublist">
                  <li>
                    <a href={withBase(item.href)} class="header__mobile-sublink">Все {item.label.toLowerCase()}</a>
                  </li>
                  {item.children.map((child) => (
                    <li>
                      <a href={withBase(child.href)} class="header__mobile-sublink">{child.label}</a>
                    </li>
                  ))}
                </ul>
              </details>
            ) : (
              <a href={withBase(item.href)} class="header__mobile-link">{item.label}</a>
            )}
          </li>
        ))}
      </ul>
    </nav>
    <div class="header__mobile-contacts">
      <a href={contactInfo.phoneHref} class="header__mobile-phone">
        {contactInfo.phone}
      </a>
      <a href={contactInfo.emailHref} class="header__mobile-email">
        {contactInfo.email}
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background-color: var(--color-surface-white);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow var(--transition-base);
  }

  .header--scrolled {
    box-shadow: var(--shadow-md);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 5rem;
    gap: var(--space-xl);
  }

  .header__logo img {
    height: 2.75rem;
    width: auto;
  }

  /* Desktop Nav */
  .header__nav-list {
    display: flex;
    gap: var(--space-xl);
  }

  .header__nav-item {
    position: relative;
  }

  .header__nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-block: var(--space-sm);
    border-bottom: 2px solid transparent;
    transition: all var(--transition-fast);
  }

  .header__nav-link:hover,
  .header__nav-link--active {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .header__nav-arrow {
    transition: transform var(--transition-fast);
    flex-shrink: 0;
  }

  .header__nav-item--has-dropdown:hover .header__nav-arrow {
    transform: rotate(180deg);
  }

  /* Dropdown */
  .header__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: -var(--space-md);
    min-width: 14rem;
    background-color: var(--color-surface-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    padding: var(--space-sm) 0;
    z-index: var(--z-dropdown, 200);
    margin-top: var(--space-xs);
  }

  .header__nav-item--has-dropdown:hover .header__dropdown,
  .header__nav-item--has-dropdown:focus-within .header__dropdown {
    display: block;
  }

  .header__dropdown-link {
    display: block;
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--text-caption);
    color: var(--color-text-primary);
    white-space: nowrap;
    transition: all var(--transition-fast);
  }

  .header__dropdown-link:hover,
  .header__dropdown-link--active {
    color: var(--color-primary);
    background-color: var(--color-surface-cream);
  }

  /* Right section */
  .header__right {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .header__phone {
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .header__phone:hover {
    color: var(--color-primary);
  }

  .header__lang {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-caption);
  }

  .header__lang-link {
    color: var(--color-text-secondary);
    font-weight: var(--weight-medium);
  }

  .header__lang-link--active {
    color: var(--color-text-primary);
    font-weight: var(--weight-bold);
  }

  .header__lang-sep {
    color: var(--color-border);
  }

  /* Burger */
  .header__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 28px;
    padding: 4px 0;
  }

  .header__burger span {
    display: block;
    height: 2px;
    background-color: var(--color-text-primary);
    border-radius: 1px;
    transition: all var(--transition-base);
  }

  /* Mobile Menu */
  .header__mobile-menu {
    display: none;
    position: fixed;
    top: 5rem;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--color-surface-white);
    padding: var(--space-2xl) var(--container-padding);
    z-index: var(--z-overlay);
    overflow-y: auto;
  }

  .header__mobile-menu[aria-hidden="false"] {
    display: block;
  }

  .header__mobile-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .header__mobile-link {
    display: block;
    font-size: var(--text-h3);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    padding: var(--space-sm) 0;
  }

  .header__mobile-link--parent {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    list-style: none;
    width: 100%;
  }

  .header__mobile-link--parent::-webkit-details-marker {
    display: none;
  }

  .header__mobile-arrow {
    transition: transform var(--transition-fast);
  }

  .header__mobile-details[open] .header__mobile-arrow {
    transform: rotate(180deg);
  }

  .header__mobile-sublist {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-sm) 0 var(--space-md) var(--space-lg);
  }

  .header__mobile-sublink {
    display: block;
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    padding: var(--space-xs) 0;
    transition: color var(--transition-fast);
  }

  .header__mobile-sublink:hover {
    color: var(--color-primary);
  }

  .header__mobile-contacts {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .header__mobile-phone {
    display: block;
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
  }

  .header__mobile-email {
    display: block;
    margin-top: var(--space-md);
    color: var(--color-text-secondary);
  }

  @media (max-width: 1023px) {
    .header__nav {
      display: none;
    }

    .header__phone {
      display: none;
    }

    .header__lang {
      display: none;
    }

    .header__burger {
      display: flex;
    }
  }
</style>

<script>
  const burger = document.getElementById('burger-btn');
  const menu = document.getElementById('mobile-menu');

  burger?.addEventListener('click', () => {
    const isOpen = menu?.getAttribute('aria-hidden') === 'false';
    menu?.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
    burger?.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });

  const header = document.getElementById('header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('header--scrolled');
    } else {
      header?.classList.remove('header--scrolled');
    }
  });
</script>
