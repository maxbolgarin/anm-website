---
import { buildingNav, buildingNavEn, contactInfo } from '@data/navigation';
import { withBase } from '@utils/withBase';
import { getLocaleFromPath } from '@utils/locale';

const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const isEn = locale === 'en';
const bNav = isEn ? buildingNavEn : buildingNav;
const prefix = isEn ? '/en' : '';
---

<footer class="footer section--dark">
  <div class="footer__inner container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href={withBase(isEn ? '/en/' : '/')} aria-label={isEn ? 'ANM — Home' : 'АНМ — Главная'}>
          <img
            src={withBase('/logo/logo vert2.svg')}
            alt={isEn ? 'Aleksandro-Nevskaya Manufaktura' : 'Александро-Невская Мануфактура'}
            class="footer__logo-img"
            loading="lazy"
          />
        </a>
        <p class="footer__desc">
          {isEn
            ? 'Property management company. Office rental in St. Petersburg business centers on the territory of Aleksandro-Nevskaya Manufaktura.'
            : 'Управляющая компания. Аренда офисов в бизнес-центрах Санкт-Петербурга на территории Александро-Невской Мануфактуры.'}
        </p>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">{isEn ? 'Business Centers' : 'Бизнес-центры'}</h4>
        <ul class="footer__list">
          {bNav.map((b) => (
            <li><a href={withBase(b.href)} class="footer__link">{b.name}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">{isEn ? 'Navigation' : 'Навигация'}</h4>
        <ul class="footer__list">
          <li><a href={withBase(`${prefix}/about/`)} class="footer__link">{isEn ? 'About' : 'О компании'}</a></li>
          <li><a href={withBase(`${prefix}/about/#territory`)} class="footer__link">{isEn ? 'Location' : 'Локация'}</a></li>
          <li><a href={withBase(`${prefix}/contacts/`)} class="footer__link">{isEn ? 'Contacts' : 'Контакты'}</a></li>
          <li><a href={withBase(`${prefix}/legal/`)} class="footer__link">{isEn ? 'Legal Information' : 'Раскрытие информации'}</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__heading">{isEn ? 'Contacts' : 'Контакты'}</h4>
        <ul class="footer__list footer__list--contacts">
          <li>
            <span class="footer__contact-label">{isEn ? 'Main' : 'Основной'}</span>
            <a href={contactInfo.phoneHref} class="footer__link footer__link--phone">{contactInfo.phone}</a>
          </li>
          <li>
            <span class="footer__contact-label">{isEn ? 'Commercial Dept.' : 'Коммерческий отдел'}</span>
            <a href={contactInfo.commercialHref} class="footer__link">{contactInfo.commercial}</a>
          </li>
          <li>
            <span class="footer__contact-label">Email</span>
            <a href={contactInfo.emailHref} class="footer__link">{contactInfo.email}</a>
          </li>
        </ul>
        <p class="footer__address">{isEn ? 'Saint Petersburg, Obukhovskoy Oborony Ave. 70, Bldg. 2, Lit. A' : contactInfo.address}</p>
      </div>
    </div>

    <div class="footer__bottom">
      <span class="footer__copyright">&copy; {new Date().getFullYear()} {isEn ? 'ANM. All rights reserved.' : 'АНМ. Все права защищены.'}</span>
      <div class="footer__legal">
        <a href={withBase(`${prefix}/legal/`)} class="footer__link">{isEn ? 'Legal Information' : 'Раскрытие информации'}</a>
        <a href={withBase(`${prefix}/legal/#requisites`)} class="footer__link">{isEn ? 'Requisites' : 'Реквизиты'}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-block: var(--space-3xl) var(--space-xl);
    background-color: #161616;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
    gap: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .footer__brand img {
    height: 180px;
    width: auto;
    margin-bottom: var(--space-lg);
  }

  .footer__desc {
    font-size: var(--text-caption);
    color: rgba(255, 255, 255, 0.65);
    line-height: var(--leading-relaxed);
  }

  .footer__heading {
    font-size: var(--text-caption);
    font-weight: var(--weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: var(--space-lg);
  }

  .footer__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__list--contacts li {
    margin-bottom: var(--space-md);
  }

  .footer__contact-label {
    display: block;
    font-size: var(--text-small);
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: var(--space-xs);
  }

  .footer__link {
    font-size: var(--text-caption);
    color: rgba(255, 255, 255, 0.85);
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--color-text-inverse);
  }

  .footer__link--phone {
    font-size: var(--text-body);
    font-weight: var(--weight-semibold);
  }

  .footer__address {
    font-size: var(--text-small);
    color: rgba(255, 255, 255, 0.5);
    margin-top: var(--space-md);
    line-height: var(--leading-relaxed);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-lg);
  }

  .footer__copyright {
    font-size: var(--text-small);
    color: rgba(255, 255, 255, 0.4);
  }

  .footer__legal {
    display: flex;
    gap: var(--space-lg);
  }

  @media (max-width: 1023px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 767px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }

    .footer__bottom {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }
  }
</style>
