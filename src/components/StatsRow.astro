---
interface StatItem {
  value: string | number;
  label: string;
  unit?: string;
}

interface Props {
  stats: StatItem[];
  columns?: number;
}

const { stats, columns } = Astro.props;
---

<div class="stats-row" data-columns={columns}>
  {stats.map((stat) => (
    <div class="stats-row__item">
      <span class="stats-row__value">
        {stat.value}
        {stat.unit && <span class="stats-row__unit">{stat.unit}</span>}
      </span>
      <span class="stats-row__label">{stat.label}</span>
    </div>
  ))}
</div>

<style>
  /* Default: all items in one flexible row */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(0, auto));
    gap: var(--space-lg) var(--space-2xl);
    justify-content: start;
  }

  /* Fixed 2-column grid (for building pages with 4 stats) */
  .stats-row[data-columns="2"] {
    grid-template-columns: auto auto;
  }

  .stats-row__item {
    display: flex;
    flex-direction: column;
  }

  .stats-row__value {
    font-family: var(--font-heading);
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    line-height: 1.0;
  }

  .stats-row__unit {
    font-size: var(--text-h3);
    font-weight: var(--weight-regular);
    color: var(--color-text-secondary);
  }

  .stats-row__label {
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    margin-top: var(--space-xs);
    white-space: nowrap;
  }

  @media (max-width: 767px) {
    .stats-row {
      grid-template-columns: repeat(2, auto);
      gap: var(--space-lg) var(--space-xl);
    }

    .stats-row__value {
      font-size: var(--text-h2);
    }
  }
</style>
