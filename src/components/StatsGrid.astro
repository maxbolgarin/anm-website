---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  stats: Stat[];
}

const { title = 'Почему выбирают нас', subtitle, stats } = Astro.props;
---

<section class="stats-grid section section--cream">
  <div class="container">
    <div class="stats-grid__header">
      <h2 class="stats-grid__title">{title}</h2>
      {subtitle && <p class="stats-grid__subtitle">{subtitle}</p>}
    </div>
    <div class="stats-grid__items">
      {stats.map((stat) => (
        <div class="stats-grid__item">
          <span class="stats-grid__value">{stat.value}</span>
          <span class="stats-grid__label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats-grid__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .stats-grid__title {
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .stats-grid__subtitle {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
  }

  .stats-grid__items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
  }

  .stats-grid__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    padding: var(--space-xl) var(--space-md);
    background-color: var(--color-surface-white);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .stats-grid__value {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    line-height: 1.1;
  }

  .stats-grid__label {
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: var(--leading-normal);
  }

  @media (max-width: 1023px) {
    .stats-grid__items {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .stats-grid__items {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }

    .stats-grid__item {
      padding: var(--space-lg) var(--space-sm);
    }
  }
</style>
