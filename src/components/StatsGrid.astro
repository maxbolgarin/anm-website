---
import { getLocaleFromPath } from '@utils/locale';

interface Stat {
  value: string;
  label: string;
}

interface Advantage {
  icon: string;
  label: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  stats: Stat[];
  advantages?: Advantage[];
}

const { title: titleProp, subtitle, stats, advantages = [] } = Astro.props;
const currentPath = Astro.url.pathname;
const locale = getLocaleFromPath(currentPath);
const isEn = locale === 'en';
const title = titleProp || (isEn ? 'Why Choose Us' : 'Почему выбирают нас');
---

<section class="stats-grid section section--cream">
  <div class="container">
    <div class="stats-grid__header">
      <h2 class="stats-grid__title">{title}</h2>
      {subtitle && <p class="stats-grid__subtitle">{subtitle}</p>}
    </div>

    <!-- Stats row -->
    {stats.length > 0 && (
      <div class="stats-grid__items">
        {stats.map((stat) => (
          <div class="stats-grid__item">
            <span class="stats-grid__value">{stat.value}</span>
            <span class="stats-grid__label">{stat.label}</span>
          </div>
        ))}
      </div>
    )}

    <!-- Advantages grid with icons -->
    {advantages.length > 0 && (
      <div class:list={["advantages", { "advantages--no-stats": stats.length === 0 }]}>
        <div class="advantages__grid">
          {advantages.map((adv) => (
            <div class="advantages__item">
              <div class="advantages__icon-wrapper">
                <img src={adv.icon} alt={adv.label} class="advantages__icon" loading="lazy" />
              </div>
              <span class="advantages__label">{adv.label}</span>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .stats-grid__header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .stats-grid__title {
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    margin-bottom: var(--space-sm);
  }

  .stats-grid__subtitle {
    font-size: var(--text-body);
    color: var(--color-text-secondary);
  }

  .stats-grid__items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-xl);
  }

  .stats-grid__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    padding: var(--space-xl) var(--space-md);
    background-color: var(--color-surface-white);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .stats-grid__value {
    font-size: var(--text-h3);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    line-height: 1.1;
  }

  .stats-grid__label {
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: var(--leading-normal);
  }

  /* Advantages */
  .advantages {
    margin-top: var(--space-3xl);
  }

  .advantages--no-stats {
    margin-top: 0;
  }

  .advantages__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-xl) var(--space-lg);
  }

  .advantages__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-xs);
    border-radius: var(--radius-md);
    transition: transform 0.2s ease;
  }

  .advantages__item:hover {
    transform: translateY(-4px);
  }

  .advantages__icon-wrapper {
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: transparent;
    border: 2px solid var(--color-primary);
    flex-shrink: 0;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .advantages__item:hover .advantages__icon-wrapper {
    background-color: rgba(183, 28, 28, 0.04);
    border-color: var(--color-primary-dark);
  }

  .advantages__icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
  }

  .advantages__label {
    font-size: var(--text-caption);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    line-height: var(--leading-normal);
    max-width: 140px;
  }

  @media (max-width: 1023px) {
    .stats-grid__items {
      grid-template-columns: repeat(2, 1fr);
    }

    .advantages__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-lg);
    }

    .advantages__icon-wrapper {
      width: 80px;
      height: 80px;
    }

    .advantages__icon {
      width: 40px;
      height: 40px;
    }
  }

  @media (max-width: 767px) {
    .stats-grid__items {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }

    .stats-grid__item {
      padding: var(--space-lg) var(--space-sm);
    }

    .advantages__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }

    .advantages__icon-wrapper {
      width: 64px;
      height: 64px;
    }

    .advantages__icon {
      width: 36px;
      height: 36px;
    }
  }
</style>
